APP_ENV=production
SECRET_KEY=replace-with-strong-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-admin-password
AUTH_KEY_VERSION=v1
CORS_ALLOW_ORIGINS=https://app.example.com,https://ops.example.com
ENABLE_DEMO_OFFICER_USER=false
OFFICER_USERNAME=
OFFICER_PASSWORD=
OUTPUT_STORE_ADAPTER=db
DB_OUTPUT_DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST/DBNAME?sslmode=require
JOB_QUEUE_DB_PATH=/var/data/job_queue.db
JOB_MAX_ATTEMPTS=3
JOB_RETRY_BACKOFF_SECONDS=0.2
JOB_TIMEOUT_SECONDS=60
JOB_RUNNING_STALE_SECONDS=300
JOB_MAX_QUEUED_JOBS=500
LOGIN_RATE_LIMIT=30
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
